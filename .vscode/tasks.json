{
    // Support tasks for running Cairn in pure Python (without Docker).
    // They all use the local dev settings (SQLite + in-memory channels)
    // and the interpreter selected by the Python extension (mise), so no
    // external dependency is required.
    "version": "2.0.0",
    "tasks": [
        {
            // Pre-launch step for F5. It ONLY compiles translation catalogs
            // (.po -> .mo) so the UI renders in French; it deliberately does NOT
            // migrate or seed. On a fresh database the first-run onboarding screen
            // applies the migrations (with a live progress bar) and then lets you
            // create an admin or load the Voltara Energy demo dataset, so the whole
            // setup is visible in the browser. compilemessages is DB-free and
            // non-fatal: if the gettext `msgfmt` binary is missing it is skipped
            // (the UI falls back to English) and F5 still launches.
            "label": "stack: bootstrap",
            "type": "shell",
            "command": "${command:python.interpreterPath} manage.py compilemessages || true",
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "DJANGO_SETTINGS_MODULE": "core.settings_local"
                }
            },
            "presentation": {
                "reveal": "silent",
                "panel": "shared",
                "close": true
            },
            "problemMatcher": []
        },
        {
            // Applies all migrations on demand (data migrations included). Normally
            // the onboarding screen does this for you on a fresh database; use this
            // only if you prefer to migrate from the CLI before launching.
            "label": "stack: migrate",
            "type": "shell",
            "command": "${command:python.interpreterPath} manage.py migrate --noinput",
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "DJANGO_SETTINGS_MODULE": "core.settings_local"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            // Reloads the Voltara Energy demo dataset on demand (same idempotence
            // guard as the bootstrap). To start from a clean dataset,
            // delete db.sqlite3 first.
            // Login: elise.moreau@voltara.example / VoltaraDemo!2026
            "label": "stack: seed-demo",
            "type": "shell",
            "command": "${command:python.interpreterPath} manage.py shell -c \"from accounts.models import User; print('Demo data already present - skipping seed.') if User.objects.filter(email='elise.moreau@voltara.example').exists() else exec(open('scripts/seed_demo_data.py').read())\"",
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "DJANGO_SETTINGS_MODULE": "core.settings_local"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            // Creates an additional super administrator (interactive). Optional:
            // the demo seed already creates a super-admin (elise.moreau@voltara.example).
            "label": "stack: createsuperuser",
            "type": "shell",
            "command": "${command:python.interpreterPath} manage.py createsuperuser",
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "DJANGO_SETTINGS_MODULE": "core.settings_local"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            // Recompiles the translation catalogs (.po -> .mo) on demand. The
            // bootstrap task already does this on F5; use this after editing a
            // locale/*.po file without restarting the server. Requires the
            // gettext `msgfmt` binary (brew/apt install gettext).
            "label": "stack: compile messages",
            "type": "shell",
            "command": "${command:python.interpreterPath} manage.py compilemessages",
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "DJANGO_SETTINGS_MODULE": "core.settings_local"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}
